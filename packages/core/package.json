{
  "name": "@canvas-harness/core",
  "version": "0.0.0",
  "description": "Canvas-rendered node-graph library — framework-agnostic core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "roughjs": "^4.6.6",
    "signia": "^0.1.5"
  },
  "devDependencies": {
    "@vitest/browser": "^3.0.0",
    "playwright": "^1.49.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
